{
  "name": "@manzoid2/archdoc",
  "version": "0.1.0",
  "description": "AI-powered codebase wiki generator",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "archdoc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "postinstall": "echo '\n  Run \"archdoc init\" to install dependencies and register with Claude Code.\n'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "ora": "^8.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
